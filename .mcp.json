{
  "name": "agent-delegation-mcp",
  "description": "Agent Delegation MCP server. Tools: create task, delegate task, get task status. Built by MEOK AI Labs.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "create_task",
      "description": "Create a new delegatable task. Required capabilities as comma-separated string.",
      "parameters": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          },
          "required_capabilities": {
            "type": "string"
          },
          "timeout_seconds": {
            "type": "integer"
          }
        },
        "required": [
          "title",
          "description"
        ]
      }
    },
    {
      "name": "delegate_task",
      "description": "Assign a pending task to a specific agent.",
      "parameters": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string"
          },
          "agent_id": {
            "type": "string"
          }
        },
        "required": [
          "task_id",
          "agent_id"
        ]
      }
    },
    {
      "name": "get_task_status",
      "description": "Check the current status and progress of a task.",
      "parameters": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string"
          },
          "include_history": {
            "type": "boolean"
          }
        },
        "required": [
          "task_id"
        ]
      }
    },
    {
      "name": "list_available_agents",
      "description": "List all registered agents and their capabilities. Optionally filter by required capability.",
      "parameters": {
        "type": "object",
        "properties": {
          "capability_filter": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "complete_task",
      "description": "Mark a task as complete with results, or as failed with error details.",
      "parameters": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string"
          },
          "result": {
            "type": "string"
          },
          "success": {
            "type": "boolean"
          }
        },
        "required": [
          "task_id",
          "result"
        ]
      }
    }
  ]
}